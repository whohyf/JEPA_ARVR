#!/bin/bash
#SBATCH --job-name=VJEPA2-EXP__hdepic_enclora_binary_dbg
#SBATCH --account=your_slurm_account
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gres=gpu:h200:1
#SBATCH --cpus-per-task=12
#SBATCH --mem=240GB
#SBATCH --time=01:00:00
#SBATCH --output=/path/to/VJEPA2-EXP/logs/hdepic_encoder_lora_%j.out
#SBATCH --error=/path/to/VJEPA2-EXP/logs/hdepic_encoder_lora_%j.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=<email>

set -euo pipefail

# Debug rerun for B5 encoder-LoRA + binary input adapter after the CPU/CUDA
# placement failure in job 10413343. Keep this limited until the first epoch-0
# forward/backward clears on HPC.

PROJECT_ROOT="${PROJECT_ROOT:-/path/to/VJEPA2-EXP}"

export PROJECT_ROOT
export GAZE_MODE=binary_input_adapter
export LORA_TAG="${LORA_TAG:-hdepic-encoderlora-gaze-binary-r64-last12-5ep}"
export CONFIG_PATH="${CONFIG_PATH:-${PROJECT_ROOT}/configs/generated/hdepic_lora_encoder_lora_gaze_binary.yaml}"
export OUTPUT_DIR="${OUTPUT_DIR:-${PROJECT_ROOT}/outputs/hdepic_lora_action_anticipation}"
export RESUME_CHECKPOINT="${RESUME_CHECKPOINT:-0}"
export VAL_ONLY=0

export EVAL_NUM_EPOCHS="${EVAL_NUM_EPOCHS:-5}"
export EVAL_BATCH_SIZE="${EVAL_BATCH_SIZE:-2}"
export EVAL_NUM_WORKERS="${EVAL_NUM_WORKERS:-12}"
export EVAL_VAL_NUM_WORKERS="${EVAL_VAL_NUM_WORKERS:-4}"
export EVAL_MAX_TRAIN_ITERS="${EVAL_MAX_TRAIN_ITERS:-15}"
export EVAL_MAX_LR="${EVAL_MAX_LR:-0.002}"
export EVAL_LR_SCALE="${EVAL_LR_SCALE:-1}"

export LORA_RANK="${LORA_RANK:-16}"
export LORA_ALPHA="${LORA_ALPHA:-32}"
export LORA_DROPOUT="${LORA_DROPOUT:-0.05}"

export ENCODER_LORA_ENABLED=1
export ENCODER_LORA_RANK="${ENCODER_LORA_RANK:-16}"
export ENCODER_LORA_ALPHA="${ENCODER_LORA_ALPHA:-32}"
export ENCODER_LORA_DROPOUT="${ENCODER_LORA_DROPOUT:-0.05}"
export ENCODER_LORA_LAST_N_BLOCKS="${ENCODER_LORA_LAST_N_BLOCKS:-12}"
export ENCODER_LORA_LR_MULT="${ENCODER_LORA_LR_MULT:-0.5}"
export ENCODER_LORA_WEIGHT_DECAY="${ENCODER_LORA_WEIGHT_DECAY:-0.0001}"
export ENCODER_LORA_ACTIVATION_CHECKPOINTING="${ENCODER_LORA_ACTIVATION_CHECKPOINTING:-1}"

export BINARY_INPUT_ADAPTER_AUG_AWARE="${BINARY_INPUT_ADAPTER_AUG_AWARE:-1}"
export BINARY_INPUT_ADAPTER_DISABLE_TRAIN_AUG="${BINARY_INPUT_ADAPTER_DISABLE_TRAIN_AUG:-0}"
export GAZE_BINARY_RADIUS_PX="${GAZE_BINARY_RADIUS_PX:-64}"
export GAZE_BINARY_MAP_TYPE="${GAZE_BINARY_MAP_TYPE:-binary}"
export BINARY_INPUT_ADAPTER_HIDDEN_DIM="${BINARY_INPUT_ADAPTER_HIDDEN_DIM:-8}"
export BINARY_INPUT_ADAPTER_TEMPORAL_KERNEL="${BINARY_INPUT_ADAPTER_TEMPORAL_KERNEL:-1}"
export BINARY_INPUT_ADAPTER_SCALE="${BINARY_INPUT_ADAPTER_SCALE:-1.0}"
export BINARY_INPUT_ADAPTER_RESIDUAL_CLAMP="${BINARY_INPUT_ADAPTER_RESIDUAL_CLAMP:-1.0}"
export BINARY_INPUT_ADAPTER_LR_MULT="${BINARY_INPUT_ADAPTER_LR_MULT:-0.05}"
export BINARY_INPUT_ADAPTER_WEIGHT_DECAY="${BINARY_INPUT_ADAPTER_WEIGHT_DECAY:-0.0001}"
export BINARY_INPUT_ADAPTER_ACTIVATION_CHECKPOINTING="${BINARY_INPUT_ADAPTER_ACTIVATION_CHECKPOINTING:-1}"
export BINARY_INPUT_ADAPTER_FORCE_ZERO_MAP=0
export BINARY_INPUT_ADAPTER_LOAD_CHECKPOINT=""

bash "${PROJECT_ROOT}/scripts/run_hdepic_lora_probe.slurm"
